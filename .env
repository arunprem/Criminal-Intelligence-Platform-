# ─── Elasticsearch ───────────────────────────────────────────────────────────
# For Docker containers (API, workers): http://es01:9200
# For host access (scripts, bootstrap): http://localhost:9201
ES_HOSTS=http://localhost:9201
ES_USERNAME=elastic
ES_PASSWORD=changeme
ES_CA_CERT=
ES_REQUEST_TIMEOUT=60
ES_MAX_RETRIES=3

# ─── Raw Source Indices (IMMUTABLE) ──────────────────────────────────────────
RAW_INDEX_ACCUSED=accused
RAW_INDEX_VICTIM=victim
RAW_INDEX_COMPLAINANT=complainant
RAW_INDEX_WITNESS=witness

# ─── Intelligence Indices ─────────────────────────────────────────────────────
INDEX_NORMALIZED_PERSON=normalized_person
INDEX_MASTER_PERSON=master_person
INDEX_RELATIONSHIPS=relationships
INDEX_RELATIONSHIP_EVENTS=relationship_events
INDEX_CHECKPOINT=pipeline_checkpoints

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PERSON_RAW=person_raw
KAFKA_TOPIC_PERSON_NORMALIZED=person_normalized
KAFKA_TOPIC_PERSON_RESOLVED=person_resolved
KAFKA_TOPIC_RELATIONSHIPS_GENERATED=relationships_generated
KAFKA_TOPIC_REVIEW_QUEUE=review_queue
KAFKA_CONSUMER_GROUP_NORMALIZATION=normalization-workers
KAFKA_CONSUMER_GROUP_RESOLUTION=resolution-workers
KAFKA_CONSUMER_GROUP_RELATIONSHIP=relationship-workers
KAFKA_CONSUMER_GROUP_GRAPH=graph-workers

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── FastAPI ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_DEBUG=false
API_SECRET_KEY=change-me-in-production

# ─── Entity Resolution Thresholds ─────────────────────────────────────────────
ER_AUTO_MERGE_THRESHOLD=0.75
ER_REVIEW_THRESHOLD=0.55
ER_MAX_CANDIDATES=100
ER_BATCH_SIZE=500

# ─── Batch Processing ─────────────────────────────────────────────────────────
BATCH_SIZE=500
BATCH_CHECKPOINT_EVERY=10000
BATCH_WORKERS=4
BATCH_MAX_RETRIES=5

# ─── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_ENABLED=false            # set true when model is available
EMBEDDING_DIMENSIONS=384

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
ENVIRONMENT=development

# ─── Remote Source Server ─────────────────────────────────────────────────────
# Replace with your actual server IP/hostname, e.g., http://192.168.1.100:9200
REMOTE_ES_URL=http://your-server-ip:9200
REMOTE_ES_USERNAME=
REMOTE_ES_PASSWORD=
